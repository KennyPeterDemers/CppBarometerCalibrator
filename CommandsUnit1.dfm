  object Memo1: TMemo
    Left = 24
    Top = 16
    Width = 489
    Height = 281
    BorderStyle = bsNone
    Font.Charset = DEFAULT_CHARSET
    Font.Color = clBlue
    Font.Height = -11
    Font.Name = 'Courier New'
    Font.Style = []
    Lines.Strings = (
      'SCRIPT COMMANDS:'
      '--------------------------------------------------------'
      'PC I s        INIT PRESSURE CONTROLLER. WAIT s SECONDS'
      'PC P n s      SET PRESSURE n (mB). WAIT s SECONDS'
      'PC S          STOP PRESSURE CONTROLLER'
      ''
      'TC I s        INIT TEMP CHAMBER. WAIT s SECONDS'
      'TC T n s      SET TEMPERATURE n (C). WAIT s SECONDS'
      'TC S          STOP TEMPERATURE CONTROLLER'
      ''
      'BA E p s      SEND esc TO BARO PORT p. WAIT s SECONDS'
      'BA C cmd, p s SEND cmd TO BARO PORT p, WAIT s SECONDS'
      'BA R p s      READ BARO PORT p (1-48). WAIT s SECONDS'
      '              If p=0, all active ports are processed'
      ''
      'GOSUB s       GO TO SUBROUTINE LABEL s'
      'RET           RETURN FROM SUBROUTINE'
      'WA s          WAIT s SECONDS'
      'ST            STOP'
      ''
      'BAROMETER COMMANDS:'
      '---------------------------------------------------------------'
      'CMD100 n   OUTPUT PERIOD (0-60 sec)'
      'CMD105 n   AVG SAMPLE COUNT (0-32)'
      'CMD110 n   OUTPUT FORMAT (1=ASCII 2=POLLED 3=NMEA 4=RAW 5=DIAG)'
      'CMD120 n   MULTIPLIER (10000 = 1.0000)'
      'CMD125 n   OFFSET (hPA x 100)'
      'CMD130 n   SEA LEVEL CORRECTION (hPA x 100)'
      'CMD140 n   VOUT RANGE HI (500-1100)'
      'CMD142 n   VOUT RANGE LO (500-1100)'
      'CMD144 n   VOUT SCALE (2=2.5V 5=5V)'
      'CMD150 c   POLL ADDR CHAR'
      'CMD160 n   BAUD RATE (38400,9600,4800,2400,1200) '
      ''
      'CMD300 n   1=STOP, 2=RUN'
      'CMD310 n   FORCE VOUT (0-5000 FULL SCALE) (or IOUT 0-2000 FS)'
      'CMD400 n   1=RPT VERBOSE, 2=RPT TERSE)'
      'CMD410     GET CAL TABLE'
      'CMD420     STORE SETUP PARAMETERS'
      'CMD430     GET CAL COUNTS'
      '  '
      'CMD910     ERASE ALL RAW DATA'
      'CMD920     ERASE CALIBRATION TABLE'
      'CMD930     ERASE SETUP PARAMETERS'
      'CMD940 r c STORE CURRENT RAW DATA AT DATA[r][c]'
      'CMD950     CALC & STORE CAL TABLE'
      'CMD960     GET RAW DATA'
      ''
      'CMD970 n   SET VOUT 2.5V MULT (or IOUT MULT)'
      'CMD972 n   SET VOUT 2.5V OFFSET (or IOUT OFFSET)'
      'CMD974 n   SET VOUT 5V MULT'
      'CMD976 n   SET VOUT 5V OFFSET'
      ''
      'CMD992 r c val STORE VAL IN RAWP[r][c]'
      'CMD994 r c val STORE VAL IN RAWT[r][c]')
    ParentFont = False
    ReadOnly = True
    ScrollBars = ssVertical
    TabOrder = 0
  end
end
