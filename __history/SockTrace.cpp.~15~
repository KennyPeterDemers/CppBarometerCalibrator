static FILE*  g_rtFile = nullptr;
static HANDLE g_rtHandle = nullptr;
static bool   g_durableFlush = true;
static bool   g_rtHeaderWritten = false;

static uint32_t g_prevTickForRt = 0;
static bool g_firstRt = true;

void SockTracer::Init(size_t maxEntries, size_t maxBytesToDump)
{
    if (!g_inited)
    {
				InitializeCriticalSection(&g_cs);
        g_inited = true;
    }
		g_maxEntries = maxEntries;
		g_maxDumpBytes = maxBytesToDump;
		g_seq = 0;
}

void SockTracer::EnsureInit()
{
    if (!g_inited)
        Init();
}


static std::string ToHex(const uint8_t* p, size_t n)
{
		static const char* k = "0123456789ABCDEF";
		std::string s;
		s.reserve(n * 3);
		for (size_t i = 0; i < n; i++)
		{
				uint8_t b = p[i];
				s.push_back(k[b >> 4]);
				s.push_back(k[b & 0xF]);
				s.push_back(' ');
		}
		return s;
}

static std::string ToAscii(const uint8_t* p, size_t n)
{
		std::string s;
		s.reserve(n);
		for (size_t i = 0; i < n; i++)
		{
				const uint8_t b = p[i];
				s.push_back((b >= 32 && b <= 126) ? (char)b : '.');
		}
		return s;
}

static const char* CtrlName(uint8_t b)
{
    switch (b)
    {
        case 0x1B: return "ESC";
        case 0x0D: return "CR";
        case 0x0A: return "LF";
        case 0x09: return "TAB";
        //case 0x20: return "SPACE";
        default:   return nullptr;
    }
}

static std::string ToAsciiNote(const uint8_t* p, size_t n)
{
    std::string s;
    for (size_t i = 0; i < n; i++)
    {
        const char* name = CtrlName(p[i]);
        if (!name) continue;

        // add "i:NAME " tokens
        char buf[32];
        std::snprintf(buf, sizeof(buf), "%u:%s ", (unsigned)i, name);
        s += buf;
    }

    // trim trailing space
    if (!s.empty() && s.back() == ' ') s.pop_back();
    return s;
}

static bool IsEmptyFile(FILE* f)
{
    if (!f) return true;
    long cur = ftell(f);
    fseek(f, 0, SEEK_END);
    long end = ftell(f);
    fseek(f, cur, SEEK_SET);
    return (end <= 0);
}

static void RtWriteHeaderIfNeeded()
{
    if (!g_rtFile || g_rtHeaderWritten) return;

    if (IsEmptyFile(g_rtFile))
    {
        fprintf(g_rtFile, "Seq\tTickMs\tDeltaMs\tThreadId\tEndpoint\tDir\tBytes\tHex\tAscii\tAsciiNote\r\n");
        fflush(g_rtFile);
        if (g_durableFlush && g_rtHandle) FlushFileBuffers(g_rtHandle);
    }

    g_rtHeaderWritten = true;
}

static void RtFlush()
{
    if (!g_rtFile) return;
    fflush(g_rtFile);
    if (g_durableFlush && g_rtHandle)
        FlushFileBuffers(g_rtHandle);
}

static void RtWriteEntry(const SockTraceEntry& e, uint32_t deltaMs)
{
    if (!g_rtFile) return;

    RtWriteHeaderIfNeeded();

    const char* dir =
        (e.kind == TraceKind::Tx) ? "TX" :
        (e.kind == TraceKind::Rx) ? "RX" : "NOTE";

    if (e.kind == TraceKind::Note)
    {
        // For NOTE entries, you currently store text in endpoint
        fprintf(g_rtFile, "%llu\t%u\t%u\t%u\t%s\t%s\t%d\t\t\t\r\n",
            (unsigned long long)e.seq,
            (unsigned)e.tickMs,
            (unsigned)deltaMs,
            (unsigned)e.threadId,
            e.endpoint.c_str(),
            dir,
            0);
    }
    else
    {
        fprintf(g_rtFile, "%llu\t%u\t%u\t%u\t%s\t%s\t%d\t%s\t%s\t%s\r\n",
            (unsigned long long)e.seq,
            (unsigned)e.tickMs,
            (unsigned)deltaMs,
            (unsigned)e.threadId,
            e.endpoint.c_str(),
            dir,
            e.bytes,
            e.hex.c_str(),
            e.ascii.c_str(),
            e.asciiNote.c_str());
    }

    RtFlush();
}

void SockTracer::Log(TraceKind kind, const char* text)
{
    EnsureInit();
		EnterCriticalSection(&g_cs);

		 SockTraceEntry e;
    e.seq = ++g_seq;
    e.tickMs = GetTickCount();
    e.threadId = GetCurrentThreadId();
		e.endpoint = text;
		e.kind = kind;

		uint32_t deltaMs = g_firstRt ? 0u : (e.tickMs - g_prevTickForRt);
		g_firstRt = false;
		g_prevTickForRt = e.tickMs;

		RtWriteEntry(e, deltaMs);

		LeaveCriticalSection(&g_cs);
}

void SockTracer::Log(bool isTx, const char* endpoint, const void* data, int bytes)
{
    EnsureInit();
		if (!endpoint)
		{
			endpoint = "";
		}
		if (!data || bytes <= 0)
		{
			return;
		}
		EnterCriticalSection(&g_cs);

		SockTraceEntry e;
    e.seq = ++g_seq;
    e.tickMs = GetTickCount();
		e.threadId = GetCurrentThreadId();
    e.endpoint = endpoint;
		if (isTx == true) {
			e.kind = TraceKind::Tx;
		} else {
			e.kind = TraceKind::Rx;
		}
    e.bytes = bytes;

    size_t n = (size_t)bytes;
		if (n > g_maxDumpBytes)
		{
			n = g_maxDumpBytes;
		}
		e.hex = ToHex((const uint8_t*)data, n);
		e.ascii = ToAscii((const uint8_t*)data, n);
		e.asciiNote = ToAsciiNote((const uint8_t*)data, n);

		if ((size_t)bytes > n)
		{
				e.hex += "...";
				e.ascii += "..."; \
		}
		uint32_t deltaMs = g_firstRt ? 0u : (e.tickMs - g_prevTickForRt);
		g_firstRt = false;
		g_prevTickForRt = e.tickMs;

		RtWriteEntry(e, deltaMs);

    LeaveCriticalSection(&g_cs);
}

bool SockTracer::StartRealtimeFile(const wchar_t* path, bool durableFlush)
{
    EnsureInit();
    EnterCriticalSection(&g_cs);

    // Close any previous file
    if (g_rtFile)
    {
        fclose(g_rtFile);
        g_rtFile = nullptr;
        g_rtHandle = nullptr;
    }

    g_durableFlush = durableFlush;
    g_rtHeaderWritten = false;

    // Append in binary so we control line endings and don’t get surprises
    g_rtFile = _wfopen(path, L"ab");
    if (!g_rtFile)
    {
        LeaveCriticalSection(&g_cs);
        return false;
    }

    // Make CRT buffering minimal (we still fflush each line)
    setvbuf(g_rtFile, nullptr, _IONBF, 0);

    int fd = _fileno(g_rtFile);
    intptr_t osfh = _get_osfhandle(fd);
    g_rtHandle = (osfh == -1) ? nullptr : (HANDLE)osfh;

    // If file is empty, header will be written on first entry
    LeaveCriticalSection(&g_cs);
    return true;
}

void SockTracer::StopRealtimeFile()
{
    EnsureInit();
    EnterCriticalSection(&g_cs);

    if (g_rtFile)
    {
        fflush(g_rtFile);
        if (g_durableFlush && g_rtHandle)
            FlushFileBuffers(g_rtHandle);

        fclose(g_rtFile);
        g_rtFile = nullptr;
        g_rtHandle = nullptr;
        g_rtHeaderWritten = false;
    }

    LeaveCriticalSection(&g_cs);
}

