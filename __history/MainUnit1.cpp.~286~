bool __fastcall TForm1::PressureSet(float pressure) {
  char str[100];
  DWORD RefTickCount1, RefTickCount2, TickCount, ms;
  int ReadCount = 0;
  int ProgressBarMax, ProgressBarPos;

  // return true = error
  // return false = OK
	sprintf(str, "PressureSet(%0.2f)", pressure);
	SockTracer::Log(TraceKind::Note, str);

  if(pressure < 300.0 || pressure > 1200.0) {
    LogError("ERROR: PressureSet(), Pressure Out of Range (300 to 1200).");
    return true;
	}


	if(Active(PcSocket)) {
    try {
			sprintf(str,":sour %0.2f", pressure);
			SendTextLogged(PcSocket->Socket, str, SendTermination::LF);
			WaitCmd(2);
			SendTextLogged(PcSocket->Socket, ":outp 1",  SendTermination::LF);

      ProgressBarMax = ProgressBarCountDown->Max;
      ProgressBarPos = ProgressBarCountDown->Position;

      ProgressBarCountDown->Max = 180000;
			RefTickCount1 = ::GetTickCount();

      while(1) {
        Application->ProcessMessages();
        PressureReadingReady = false;

        PressureGet();

        RefTickCount2 = ::GetTickCount();

        while(!PressureReadingReady) {
          Application->ProcessMessages();
          if(!RunFlag) return 1;
          TickCount = ::GetTickCount() - RefTickCount2;
          if(TickCount > 5000) { // IF NO PRESSURE READING WITHING 5 SECS, ERROR
            LogError("ERROR: PressureSet(), No pressure reading available.");
            return 1;
          }
        }

        //MemoMain->SetSelTextBuf("*");

        if(fabs(pressure - CurrentPressure)  <= 0.01) ++ReadCount;
        else ReadCount=0;

        if(ReadCount >= 50) return 0; // IF 50 SUCCESSIVE READINGS WITHIN 0.01hPa, RETURN WITH VALID READING

        TickCount = ::GetTickCount() - RefTickCount1;

        ProgressBarCountDown->Position = TickCount;

        sprintf(str,"%06.1f ", (float)TickCount/1000.0);
        LabelWait->Caption = str;

        if(TickCount > TargetPressureTimeLimit) { // IF NOT SET WITHIN X SECS, ERROR
          LogError("ERROR: PressureSet(), Cannot reach target pressure.");

         ProgressBarCountDown->Max =  ProgressBarMax;
         ProgressBarCountDown->Position =  ProgressBarPos;

          return 1;
        }
      }
    }
    catch(...) {
      LogError("ERROR: Exception in PressureSet().");
    }
  }
  else LogError("ERROR: PressureSet(), Pressure Comm Port Closed.");

  ProgressBarCountDown->Max =  ProgressBarMax;
  ProgressBarCountDown->Position =  ProgressBarPos;
  return true;

}
