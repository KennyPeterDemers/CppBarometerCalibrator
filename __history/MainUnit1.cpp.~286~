    if(j) c->LineTo((int)fX, (int)fY);
    else c->MoveTo((int)fX, (int)fY);

    //sprintf(str,"%f, %f", fX, fY);
    //Form1->MemoMain->Lines->Add(str);

  }

	xMult = (float)Form1->ImageT1->Width/14.0;
  float ySpan = fCorrMax - fCorrMin;
  float yOffset = (float)Form1->ImageT1->Height * fCorrMin/ySpan;
