void BuildTable() {

  int tIndex, pIndex;
  float tAvg, tSum, x, y, x1, x2, y1, y2;

  // FOR EACH GROUP OF T/P SAMPLES AT A GIVEN TEMP,
  // CALC THE AVG TEMP THAT WILL REPRESENT THAT GROUP
  // IN THE CALTABLE.

  // USING THE AVG TEMP AS THE NEW 'Y' VALUE,
  // INTERPOLATE THE NEW 'X' (RAW PRESSURE) FOR EACH
  // OF 15 PRESSURE SAMPLES.

  // THE LAST TEMPERATURE ROW MUST BE CALCULATED
  // DIFFERENTLY.

  for(tIndex = 0; tIndex<25; tIndex++) {
    // CALC AVG T
    tSum = 0.0;
    for(pIndex=0; pIndex<15; pIndex++) {
      tSum += RawData[tIndex][pIndex].T;
    }

    tAvg = tSum/15.0;
    CalTable[tIndex][0] = tAvg;

    //sprintf(str, "Avg T: %02d %.0f", tIndex, tAvg);
    //Memo1->Lines->Add(str);

    if(tIndex<24) {

      // NORMAL CALC FOR ALL TEMPS EXCEPT LAST
      for(pIndex=0; pIndex<15; pIndex++) {
        x1 = RawData[tIndex][pIndex].P;
        y1 = RawData[tIndex][pIndex].T;
        x2 = RawData[tIndex+1][pIndex].P;
        y2 = RawData[tIndex+1][pIndex].T;

        y = tAvg;
        x = ((y-y1)*(x2-x1))/(y2-y1) + x1;

        CalTable[tIndex][pIndex+1] = x;
        //sprintf(str, "New P: %.0f", x);
        //Memo1->Lines->Add(str);
      }

    }
    else {

      // HANDLE LAST TEMP DIFFERENTLY
      for(pIndex=0; pIndex<15; pIndex++) {
        x1 = RawData[tIndex-1][pIndex].P;
        y1 = RawData[tIndex-1][pIndex].T;
        x2 = RawData[tIndex][pIndex].P;
        y2 = RawData[tIndex][pIndex].T;

        y = tAvg;
        x = ((y-y1)*(x2-x1))/(y2-y1) + x1;

        CalTable[tIndex][pIndex+1] = x;
        //sprintf(str, "LAST TEMP: %.0f %.0f %.0f %.0f %.0f %.0f", x1, y1, x2, y2, x, y);
        //Memo1->Lines->Add(str);
      }

    }
  }

}

