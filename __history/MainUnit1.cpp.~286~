void __fastcall TForm1::BaroSendMsg(int Port, const char *str) {
	int i;
	const char *ptr;
	char LocStr[100];

	sprintf(LocStr,"SendBaroMsg(%i, %s)", Port, str);
	SockTracer::Log(TraceKind::Note, LocStr);

	// Get a pointer to the script line
	ptr = str;

	// ARE WE SENDING TO ALL PORTS
	if(Port == 0) {
		// Do we have another character to send
		while(*ptr) {
			// Yes - we'll try to send it to each port
			for(i=0; i<DIGI_COMMAND_CHANNELS; i++) {
				// Is this port checked
				if(CommBox[i]->Checked) {
					// Yes - Is it connected
					if(CommSocket[i]->Active) {
						try {
							// Send the char to the port
							SendCharacterLogged(CommSocket[i]->Socket, *ptr);
						}
						catch(...) {
							sprintf(LocStr,"ERROR: Exception in SendBaroMsg() Port:%i.", i+1);
							LogError(LocStr);
						}
					}
					// No
					else {
						sprintf(LocStr,"ERROR: BaroSendMsg(), Baro Comm Port %i Closed.", i+1);
						// log to trace file not the in memory error log
						SockTracer::Log(TraceKind::Note, LocStr);
					}
				}
			}
			// Bump pointer to the next char
			++ptr;

			// If we should delay between chars
			if(EnableBaroSendCharDelay->Checked) {
				Sleep(100);
			}
		}
		// If we should delay
		if(EnableBaroSendCharDelay->Checked) {
			Sleep(100);
		}
		// If command sent was not ESC, send CR to terminate the command
		if(*str != 27 ) {
			// Regular command
			for(i=0; i<DIGI_COMMAND_CHANNELS; i++) {
				// Is the port checked
				if(CommBox[i]->Checked) {
					// Yes - is it connected
					if(CommSocket[i]->Active) {
						// Yes
						try {
							// Send the CR
							SendCharacterLogged(CommSocket[i]->Socket, '\r');
						}
						catch(...) {
							sprintf(LocStr,"ERROR: Exception in SendBaroMsg() Port %i - sending the CR.", i+1);
							LogError(LocStr);
						}
					}
					else {
						sprintf(LocStr,"ERROR: BaroSendMsg(), Baro Comm Port %i Closed.", i+1);
						// log to trace file not the in memory error log
						SockTracer::Log(TraceKind::Note, LocStr);
					}
				}
			}
		}
	}
	else {
		// SEND TO ONE PORT
		// Get the port index
		i = Port - 1;
		// while there is a character to send
		while(*ptr) {
			// Is port checked
			if(CommBox[i]->Checked) {
				// Yes - is port connected
				if(CommSocket[i]->Active) {
					// yes
					try {
						// Send the char
						SendCharacterLogged(CommSocket[i]->Socket, *ptr);
					}
					catch(...) {
						sprintf(LocStr,"ERROR: Exception in SendBaroMsg() Port %i.", i+1);
						LogError(LocStr);
					}
				}
				else {
					sprintf(LocStr,"ERROR: BaroSendMsg(), Baro Comm Port %i Closed.", i+1);
					LogError(LocStr);
				}
			}
			// Bump pointer to the next char
			++ptr;

			// If we should delay between chars
			if(EnableBaroSendCharDelay->Checked) {
				Sleep(100);
			}
		}
		// If we should delay between chars
		if(EnableBaroSendCharDelay->Checked) {
			Sleep(100);
		}
		// If not ESC, send CR to terminate the command
		if(*str != 27 ) {
			// Is port checked
			if(CommBox[i]->Checked) {
				// Yes - is port connected
				if(CommSocket[i]->Active) {
					// Yes
					try {
						// Send the CR to terminate the command
						SendCharacterLogged(CommSocket[i]->Socket, '\r');
					}
          catch(...) {
						sprintf(LocStr,"ERROR: Exception in SendBaroMsg() sending CR to Port %i.", i+1);
						LogError(LocStr);
          }
        }
        else {
          sprintf(LocStr,"ERROR: BaroSendMsg(), Baro Comm Port %i Closed.", i+1);
					LogError(LocStr);
        }
      }
    }
  }
