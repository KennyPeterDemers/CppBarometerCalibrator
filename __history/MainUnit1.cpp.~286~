void DrawGrid() {
  float xMult, yMult;
  int i, x, y, w, h;
  TCanvas *c;

  float fRange;
  int Divisions;

  switch(Form1->RadioGroupGraphSensorType->ItemIndex) {
    //case 0: fRange = 700.0;
    //        Divisions = 7;
    //        break;

    case 0:
    case 1: fRange = 600.0;
            Divisions = 6;
            break;

    case 2: fRange = 500.0;
            Divisions = 5;
            break;

    case 3: fRange = 700.0;
            Divisions = 7;
            break;
  }

  w = Form1->ImageCalCheck->Width;
  h = Form1->ImageCalCheck->Height;
  c = Form1->ImageCalCheck->Canvas;

  xMult = (float)w/fRange; // 500.0 to 1100.0 hPa
  yMult = -(float)h/1.0; // ±0.5 hPa

  c->Pen->Color = (TColor)0x00CCCCCC;
  c->Pen->Width = 1;

  for(i=0; i<=Divisions; i++) {
    y = 0;
    x = (i*w)/Divisions;
    c->MoveTo(x,y);
    y = h;
    c->LineTo(x,y);
  }

  for(i=0; i<=10; i++) {
    x = 0;
    y = (i*h)/10;
		c->MoveTo(x,y);
		x = w;
		c->LineTo(x,y);
	}

  c->Pen->Color = (TColor)0;
	x = 0;
  y = (5*h)/10;
	c->MoveTo(x,y);
	x = w;
	c->LineTo(x,y);

}

