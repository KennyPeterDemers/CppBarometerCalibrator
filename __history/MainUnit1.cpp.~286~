void GetT1() {
  char str[100], WorkString[100];
  int Port = Form1->CSpinEditPortT1Chk->Value;
  int i, j, iVal, iAddr, LineCount;
  TCanvas *c = Form1->ImageT1->Canvas;

  Application->ProcessMessages();

  Form1->BaroSendMsg(Port, "\x1B\x1B\x1B");
  Sleep(2000);
  Application->ProcessMessages();
  TableChkFlag = true;
  Form1->BaroSendMsg(Port, "T1");

  while(TableChkFlag) Application->ProcessMessages();

	Form1->BaroSendMsg(Port, "XX");

  LineCount = Form1->MemoMain->Lines->Count;
  if(LineCount == 0) {
    Form1->MemoMain->Lines->Add("No T1 Data.");
    return;
  }

  i=0;
  while(i<LineCount) {
	strcpy(WorkString, AnsiString(Form1->MemoMain->Lines->Strings[i]).c_str());
  	iAddr = atoi(&WorkString[0]);

    //iVal = atoi(&WorkString[5]);
    //sprintf(str, "%05u: %05i", iAddr, iVal);
    //MemoMain->Lines->Add(str);

    if(iAddr == 46644) break;

    ++i;
  }

  float fX, fY;
  float xMult = (float)Form1->ImageT1->Width/22.0;
  float yMult = (float)Form1->ImageT1->Height/3200.0;

  c->Pen->Color = clSilver;

  for(j=0; j<23; j++) {
    strcpy(WorkString, AnsiString(Form1->MemoMain->Lines->Strings[i+j]).c_str());
    iVal = atoi(&WorkString[5]);

    //sprintf(str, "%02i\t%03i\t%i", j, j*5-50, iVal);
    //MemoMain->Lines->Add(str);

    fX = (float)j * xMult;
    fY = (float)Form1->ImageT1->Height - (float)iVal * yMult;

    if(j) c->LineTo((int)fX, (int)fY);
    else c->MoveTo((int)fX, (int)fY);
  }

  while(i<LineCount) {
    strcpy(WorkString, AnsiString(Form1->MemoMain->Lines->Strings[i]).c_str());
    iAddr = atoi(&WorkString[0]);

    //iVal = atoi(&WorkString[5]);
    //sprintf(str, "%05u: %05i", iAddr, iVal);
    //MemoMain->Lines->Add(str);

    if(iAddr == 46690) break;
    ++i;
  }

  int CorrTable[23][9];
  int k;

	T1CorrMax = -10000;
	T1CorrMin = 10000;

  k = i;

  for(i=0; i<23; i++) {
    for(j=0; j<9; j++) {
      strcpy(WorkString, AnsiString(Form1->MemoMain->Lines->Strings[k + i*9 + j]).c_str());
      iVal = atoi(&WorkString[5]);

      CorrTable[i][j] = iVal;

      if(iVal < T1CorrMin) T1CorrMin = iVal;
      if(iVal > T1CorrMax) T1CorrMax = iVal;

      //sprintf(str, "%02i %02i:\t%i", i, j, iVal);
      //MemoMain->Lines->Add(str);

    }
  }

  xMult = (float)Form1->ImageT1->Width/8.0;
  float ySpan = (float)(T1CorrMax - T1CorrMin);
  float yOffset = (float)Form1->ImageT1->Height * (float)T1CorrMin/ySpan;
  yMult = (float)Form1->ImageT1->Height/ySpan;

  for(i=0; i<23; i++) {
    for(j=0; j<9; j++) {
      iVal = CorrTable[i][j];

      fX = xMult * (float)(j);
      fY = (float)Form1->ImageT1->Height - (float)iVal * yMult + yOffset;

      c->Pen->Color = Form1->MakeColor(5*i - 50);

      if(j) c->LineTo((int)fX, (int)fY);
      else c->MoveTo((int)fX, (int)fY);
    }
  }
}

