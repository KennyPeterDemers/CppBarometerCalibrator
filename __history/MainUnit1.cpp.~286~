void SetScriptBar() {
  int LastIndex, ScriptStepCount, ScriptCount, NewIndex;
  char *ptr, str[100];
  bool LoopFlag = true;
  char LineString[200];

  ScriptIndex = 0;
  ScriptStepCount = 0;

  #define NULL_CMD 0
  #define NO_CMD 0
  #define PC_CMD 1
  #define TC_CMD 2
  #define BA_CMD 3
  #define WA_CMD 4
  #define WV_CMD 5
  #define ST_CMD 6
  #define GOSUB_CMD 7
  #define SUB_CMD 8
  #define RET_CMD 9
  #define MODE_CMD 10

  ScriptCount = Form1->MemoScript->Lines->Count;
  ScriptIndex = 0;
  SubReturnCount = 0;

  while(LoopFlag) {

    if(ScriptIndex >= ScriptCount) {
      Form1->LogError("ERROR: SetScriptBar(), Missing ST Parameter.");
      break;
    }

    StrPLCopy(LineString, Form1->MemoScript->Lines->Strings[ScriptIndex],190);
    //Form1->MemoMain->Lines->Add(LineString);

    if(*LineString == '*') {
      ++ScriptIndex;
      continue;
    }

    ++ScriptStepCount;
    //Form1->ProgressBarScript->Position = ScriptStepCount;

		ptr = strtok(LineString, " "); // scan line, skip ' ' and '\t'

		if (ptr == NULL)
		{
				sprintf(str,"Parsing Err[%s]", LineString);
				Form1->LogError(str);
				break;
		}
		//sprintf(str,"%s",ptr);
		//Memo2->Lines->Add(str);

		if(strcmp("GOSUB",ptr) == 0) {

			ptr = strtok(NULL, " \t"); // scan line, skip ' ' and '\t'

			if(Form1->NoParam(ptr)) {
				Form1->LogError("ERROR: SetScriptBar(), Missing GOSUB Parameter.");
				break;
			}

			NewIndex = Form1->FindSubIndex(ptr);
			//sprintf(str,"NewIndex: %d String: %s", NewIndex, ptr);
			//Form1->MemoMain->Lines->Add(str);

      if(NewIndex) {
        //Memo2->Lines->Add(AStr + ScriptStringList->Strings[i]);
        SubReturnStack[++SubReturnCount] = ScriptIndex;
        ScriptIndex = NewIndex - 1;
      }
      // ERROR -- NO GOSUB TARGET
    }

    if(strcmp("RET",ptr) == 0) {
      ScriptIndex = SubReturnStack[SubReturnCount--];
    }

    if(strcmp("ST",ptr) == 0) break;

    ++ScriptIndex;

  }

  Form1->ProgressBarScript->Max = ScriptStepCount;
  Form1->ProgressBarScript->Position = 0;
  //sprintf(str,"Steps: %d  ScriptCount: %d", ScriptStepCount, ScriptCount);
  //Form1->MemoMain->Lines->Add(str);

