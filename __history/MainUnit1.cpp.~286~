#include <Windows.h>
#include <memory>

#pragma comment(lib, "version.lib")

static String GetExeFileVersion()
{
    String exe = Application->ExeName;
    AnsiString exeA = AnsiString(exe);

    DWORD handle = 0;
    DWORD size = GetFileVersionInfoSizeA(exeA.c_str(), &handle);
    if (size == 0)
        return "";

    std::unique_ptr<BYTE[]> data(new BYTE[size]);
    if (!GetFileVersionInfoA(exeA.c_str(), handle, size, data.get()))
        return "";

    VS_FIXEDFILEINFO* pffi = nullptr;
    UINT len = 0;
    if (!VerQueryValueA(data.get(), "\\", (LPVOID*)&pffi, &len) || len == 0)
        return "";

    return String().sprintf(L"%u.%u.%u.%u",
        HIWORD(pffi->dwFileVersionMS),
        LOWORD(pffi->dwFileVersionMS),
        HIWORD(pffi->dwFileVersionLS),
        LOWORD(pffi->dwFileVersionLS));
}

