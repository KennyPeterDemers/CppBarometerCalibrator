bool __fastcall TForm1::ConvertBaroRead() {

  int i, j, LineCount, PortNum;
  char *ptr, str[100];
  float fVal;

  LineCount = MemoBaroReadMon->Lines->Count;

  //sprintf(str, "LineCount: %i", LineCount);
  //StatusBar1->Panels->Items[0]->Text = str;
  
  
	for(i=1; i<(LineCount); i++) {

		// PATCH 4: guard BEFORE writing ReadBaroArray[ReadBaroIndex]
		if (ReadBaroIndex >= READ_BARO_ARRAY_MAX) {
				StatusBar1->Panels->Items[2]->Text = "ReadBaroArray full (ConvertBaroRead).";
				sprintf(str, "ConvertBaroRead overflow: ReadBaroIndex=%d, max=%d", ReadBaroIndex, READ_BARO_ARRAY_MAX);
				LogError(str);
				break; // stop converting more lines
		}

		strcpy(str, AnsiString(MemoBaroReadMon->Lines->Strings[i]).c_str());

		if(strncmp("END", str, 3) == 0) {
			CalTime = (TDateTime)atof(&str[4]);
			break;
		}

		ReadBaroArray[ReadBaroIndex].PortNum = atoi(str);
		ptr = str;
		while(*ptr != ' ') ++ptr; // Find SN
		while(*ptr == ' ') ++ptr;

		j=0;
		while(*ptr != ' ' && j<(SN_STR_LEN - 1)) {
			ReadBaroArray[ReadBaroIndex].SnStr[j] = *ptr;
      ++ptr;
			++j;
    }
		ReadBaroArray[ReadBaroIndex].SnStr[j] = 0;
    while(*ptr == ' ') ++ptr;

		ReadBaroArray[ReadBaroIndex].RefPressure = atof(ptr);

    while(*ptr != ' ') ++ptr; // Find Ref Temp
		while(*ptr == ' ') ++ptr;
    ReadBaroArray[ReadBaroIndex].RefTemp = atof(ptr);

		while(*ptr != ' ') ++ptr; // Find Pressure
    while(*ptr == ' ') ++ptr;
    ReadBaroArray[ReadBaroIndex].Pressure = atof(ptr);

		++ReadBaroIndex;
	}

	return false; //OK

}
