void GetDash72Table() {
  char str[100], *ptr, WorkString[200];
  int Port = Form1->CSpinEditPortT1Chk->Value;
  int i, j, index, iVal, iAddr, LineCount;
  TCanvas *c = Form1->ImageT1->Canvas;
  float T[13], P[13][10];
  float fVal, fCorrMin = 999999999.0, fCorrMax = -9999999999.0;

  Form1->MemoMain->Clear();

  sprintf(str, "BARO PAUSE, PORT %d...", Port);
  Form1->MemoMain->Lines->Add(str);

  Form1->BaroSendMsg(Port, "CMD300 1"); // PAUSE BARO OUTPUT
  Sleep(1000);

  Form1->MemoMain->Lines->Add("GET TABLE...");

  TableChkFlag = true;
	NoActivityTime[Port-1] = 0;

  Form1->BaroSendMsg(Port, "CMD410"); // GET TABLE

  // for(i=0; i<DigiCommChannels; i++) {
  while(NoActivityTime[Port-1] < 5) {
    //sprintf(str, "NoActivityTime: %d", NoActivityTime);
    //Form1->MemoMain->Lines->Add(str);
    Sleep(250);
    Application->ProcessMessages();
    //if(NoActivityTime>3) break;
  }

  sprintf(str, "RESUME BARO OUTPUT, PORT %d...", Port);
  Form1->MemoMain->Lines->Add(str);

  TableChkFlag = false;
  Form1->BaroSendMsg(Port, "CMD300 2"); // RESUME BARO OUTPUT

  LineCount = Form1->MemoMain->Lines->Count;

  if(LineCount == 0) {
    Form1->MemoMain->Lines->Add("No Data.");
    return;
  }

  // COMMENT OUT
  //sprintf(str,"LINE COUNT:%d", LineCount);
  //Form1->MemoMain->Lines->Add(str);

  Form1->MemoMain->Lines->Add("CALCULATING...");

	i = LineCount - 14;
  index = 0;

  // FIND 12 CAL TEMPS

  while(index < 12) {
    strcpy(WorkString, AnsiString(Form1->MemoMain->Lines->Strings[i]).c_str());
    ptr = WorkString;

    sscanf(ptr,"%f", &T[index]);
    //sprintf(str,"%d %.0f", index, T[index]);
    //Form1->MemoMain->Lines->Add(str);
    ++ptr;

    // FIND 9 CAL PRESSURES

    for(j=0; j<9; j++) {
      while(*ptr != ' ') ++ptr;
      ptr += sscanf(ptr,"%f", &fVal);
      P[index][j] = fVal;
      //if(fVal<fCorrMin) fCorrMin = fVal;
      //if(fVal>fCorrMax) fCorrMax = fVal;

      //sprintf(str,"  %f", P[i-1][j]);
      //Form1->MemoMain->Lines->Add(str);
    }

    ++i;
    ++index;
  }

  /*
  for(i=0; i<13; i++) {
    for(j=0; j<10; j++) {

      if(P[12][j] == 0.0) {
        sprintf(str, "SAMPLE P[12][%d] = ZERO", j);
        Form1->MemoMain->Lines->Add(str);
        return;
      }

      //fVal = (P[i][j] - P[12][j])/P[12][j];
      //if(fVal<fCorrMin) fCorrMin = fVal;
      //if(fVal>fCorrMax) fCorrMax = fVal;
      //sprintf(str,"%d %d %f", i, j, fVal);
      //Form1->MemoMain->Lines->Add(str);
    }
  }
  */

  // THIS SETS THE VERTICAL SPAN OF THE GRAPH TO ±5hPa
  fCorrMin = -500.0;
  fCorrMax = 500.0;

  float fX, fY;
  float xMult = (float)Form1->ImageT1->Width/11.0;
  float yMult;

  if(T[11] - T[0] == 0.0) {
    Form1->MemoMain->Lines->Add("ERROR: T[11] - T[0] = 0.0");
    return;
  }

  yMult = (float)Form1->ImageT1->Height/(T[11] - T[0]);

  // COMMENT OUT
  //sprintf(str,"Mults: %f, %f", xMult, yMult);
  //Form1->MemoMain->Lines->Add(str);

  c->Pen->Color = clSilver;

  for(j=0; j<12; j++) {

    fX = (float)j * xMult;
    fY = (float)Form1->ImageT1->Height - (T[j]-T[0]) * yMult;

    if(j) c->LineTo((int)fX, (int)fY);
    else c->MoveTo((int)fX, (int)fY);

    //sprintf(str,"%f, %f", fX, fY);
    //Form1->MemoMain->Lines->Add(str);

  }

  xMult = (float)Form1->ImageT1->Width/7.0;
  float ySpan = fCorrMax - fCorrMin;

  if(ySpan == 0.0) {
    Form1->MemoMain->Lines->Add("ERROR: ySpan = 0");
    return;
  }

  float yOffset = (float)Form1->ImageT1->Height * fCorrMin/ySpan;
  yMult = (float)Form1->ImageT1->Height/ySpan;

  for(i=0; i<12; i++) {

    c->Pen->Color = Form1->MakeColor(10*i - 45);

    //sprintf(str,"%d %d", i, 10*i-55);
    //Form1->MemoMain->Lines->Add(str);

    for(j=0; j<9; j++) {
			fVal = P[i][j] - ((float)j * 10000.0 + 35000);

      //sprintf(str,"%f.0", fVal);
      //Form1->MemoMain->Lines->Add(str);
      //fVal = (P[i][j] - P[6][j])/P[6][j];

      fX = xMult * (float)(j);
      fY = (float)Form1->ImageT1->Height - fVal * yMult + yOffset;

      if(j) c->LineTo((int)fX, (int)fY);
      else c->MoveTo((int)fX, (int)fY);
    }
  }

  c->Pen->Color = clBlack;
  c->MoveTo(0, Form1->ImageT1->Height/2);
  c->LineTo(Form1->ImageT1->Width, Form1->ImageT1->Height/2);

  AnsiString serial = EditSerialNum[Port-1]->Text;   // converts UnicodeString -> AnsiString
  sprintf(str, "Port %d: %s", Port, serial.c_str());
  c->TextOut(Form1->ImageT1->Width - 90,Form1->ImageT1->Height - 20, str);

}

