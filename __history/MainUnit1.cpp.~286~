void SendSerial(char *str) {
	DWORD iBytesWritten;
	DWORD iBytesRead;
  DWORD Len;
  DWORD EventFlags, ErrorFlags;
  COMSTAT cs;

  if(hComm == 0) {
    Form1->LogError("Serial port not open for sending command.");
    return;
  }

  Len = strlen(str);

  while(1) {
    Application->ProcessMessages();
    //if(StopFlag) break;
    ClearCommError(hComm, &ErrorFlags, &cs);
    if(cs.cbOutQue == 0) break;
  }

	WriteFile(hComm, str, Len, &iBytesWritten, NULL);

  while(1) {
    Application->ProcessMessages();
    //if(StopFlag) break;
    ClearCommError(hComm, &ErrorFlags, &cs);
    if(cs.cbOutQue == 0) break;
  }

}

//--------------------------------------------------------------------------- KPD SCRIPT FILE PARSING

bool __fastcall TForm1::ParseLine() {
  char *ptr, str[100], CmdStr[20];
	char LineString[200];
	char units;
	AnsiString FileName[14], AStr, BStr, ThisTime;
  float fVal;
  int cmd, Port, i, count, WaitCount, Retries;

  #define NULL_CMD 0
  #define NO_CMD 0
  #define PC_CMD 1
  #define TC_CMD 2
  #define BA_CMD 3
  #define WA_CMD 4
  #define WV_CMD 5
  #define ST_CMD 6
  #define GOSUB_CMD 7
  #define SUB_CMD 8
  #define RET_CMD 9
  #define MODE_CMD 10

  //ProgressBar1->Position = ProgressCount;

  /*
  MemoScript->SelStart = SNDMSG(MemoScript->Handle, EM_LINEINDEX, ScriptIndex, 0);
  SNDMSG(MemoScript->Handle, EM_SCROLLCARET, 0, 0);
  MemoScript->SelLength = 2;
  */

  StrPLCopy(LineString, MemoScript->Lines->Strings[ScriptIndex],190);

  ptr = strtok(LineString, " \t"); // scan line, skip ' ' and '\t'
  //sprintf(str,"%s",ptr);
  //Memo2->Lines->Add(str);

  // KPD STORE THE COMMAND
	if(strcmp("PC",ptr) == 0) cmd = PC_CMD; // PRESSURE CONTROLLER
  else if(strcmp("TC",ptr) == 0) cmd = TC_CMD; // TEMPERATURE CONTROLLER
  else if(strcmp("BA",ptr) == 0) cmd = BA_CMD; // BAROMETER
  else if(strcmp("WA",ptr) == 0) cmd = WA_CMD; // WAIT
  else if(strcmp("ST",ptr) == 0) cmd = ST_CMD; // STOP
  else if(strcmp("GOSUB",ptr) == 0) cmd = GOSUB_CMD; // GOSUB
  else if(strcmp("RET",ptr) == 0) cmd = RET_CMD; // RETURN
  else if(strcmp("MODE",ptr) == 0) cmd = MODE_CMD; // RETURN
	else cmd = NO_CMD;

  AStr = BStr.StringOfChar(' ',4 * SubReturnCount);

	// PROCESS EACH COMMAND TYPE
  switch(cmd) {
		case RET_CMD:
			//if(NoParam(ptr)) return;
			MemoMain->Lines->Add(AStr + MemoScript->Lines->Strings[ScriptIndex]);
			ScriptIndex = SubReturnStack[SubReturnCount--];
			break;

		case MODE_CMD:
			ptr = strtok(LineString, " \t"); // scan line, skip ' ' and '\t'
			if(strcmp("RUN",ptr) == 0) ModeVal = RUN_MODE;
			else if(strcmp("CAPTURE",ptr) == 0) ModeVal = CAPTURE_MODE;
			else return true; // INVALID MODE
			break;

		case GOSUB_CMD:
			ptr = strtok(NULL," \t");
			if(NoParam(ptr)) return true; //error
			MemoMain->Lines->Add(AStr + MemoScript->Lines->Strings[ScriptIndex]);
			i = FindSubIndex(ptr);
			if(i) {
				//Memo2->Lines->Add(AStr + ScriptStringList->Strings[i]);
				SubReturnStack[++SubReturnCount] = ScriptIndex;
				ScriptIndex = i-1;
			}
			break;

			//case SUB_CMD: Memo2->Lines->Add(ScriptStringList->Strings[ScriptIndex]);
										// The SUB command is really just a label
			//              break;

		case NO_CMD:
			MemoMain->Lines->Add(AStr + MemoScript->Lines->Strings[ScriptIndex]);
			break;

		case PC_CMD:
			ptr = strtok(NULL," \t");
			if(NoParam(ptr)) return true; //error

			switch(*ptr) {
				case 'P':
					// PC P n w   Set pressure to n and wait w seconds

					ptr = strtok(NULL," \t");
					if(NoParam(ptr)) return true; //error
					fVal = atof(ptr);

					ptr = strtok(NULL," \t");
					if(NoParam(ptr)) return true; //error
					WaitCount = atoi(ptr);

					sprintf(str,"PC P %5.1f %d", fVal, WaitCount);
					MemoMain->Lines->Add(AStr + str);

					PressureSet(fVal);

					WaitCmd(WaitCount);
					break;

				case 'I':
					//PC I w  Initialize remote comm with pressure controller.
					//        Wait w seconds.

					ptr = strtok(NULL," \t");
					if(NoParam(ptr)) return true; //error
					WaitCount = atoi(ptr);

					sprintf(str,"PC I %d", WaitCount);
					MemoMain->Lines->Add(AStr + str);
					PressureInit();
					WaitCmd(WaitCount);
					break;

				case 'S':
					// PC S  Stop pressure control
					MemoMain->Lines->Add(AStr + "PC S");
					PressureStop();
					break;
			}
		break;

		case TC_CMD:
			ptr = strtok(NULL," \t");
			if(NoParam(ptr)) return true; //error

			switch(*ptr) {
				case 'T':
					// TC T n w   Set temperature to n and wait w seconds

					ptr = strtok(NULL," \t");
					if(NoParam(ptr)) return true; //error
					fVal = atof(ptr);

					ptr = strtok(NULL," \t");
					if(NoParam(ptr)) return true; //error
					WaitCount = atoi(ptr);

					sprintf(str,"TC T %4.1f %d", fVal, WaitCount);
					MemoMain->Lines->Add(AStr + str);
					TemperatureSet(fVal);
					WaitCmd(WaitCount);
					break;

				case 'I':
					// TC I w   Initialize remote comm with temperature chamber.
					//          Wait w seconds.

					ptr = strtok(NULL," \t");
					if(NoParam(ptr)) return true; //error
					WaitCount = atoi(ptr);

					sprintf(str,"TC I %d", WaitCount);
					MemoMain->Lines->Add(AStr + str);
					TemperatureInit();
					WaitCmd(WaitCount);
					break;

				case 'S':
					// TC S  Stop temperature control
					MemoMain->Lines->Add(AStr + "TC S");
					TemperatureStop();
					break;
				case 'U':
					// TC U  F/C w Set Units to C or F in temperature control & wait w Secs
					ptr = strtok(NULL," \t");
					if(NoParam(ptr)) return true; //error
					units = ptr[0];

					ptr = strtok(NULL," \t");
					if(NoParam(ptr)) return true; //error
					WaitCount = atoi(ptr);

					sprintf(str,"TC U %c %d", units, WaitCount);
					MemoMain->Lines->Add(AStr + str);
					TemperatureSetUnits(units);
					WaitCmd(WaitCount);
					break;
			}
			break;

		case BA_CMD:  ptr = strtok(NULL," \t");
			if(NoParam(ptr)) return true; //error

			switch(*ptr) {
				case 'E':
					// BA E p w   Send ESC to barometer port n, wait w seconds.
					// If n=0, send to all.

					ptr = strtok(NULL," \t");
					if(NoParam(ptr)) return true; //error
					Port = atoi(ptr);

					ptr = strtok(NULL," \t");
					if(NoParam(ptr)) return true; //error
					WaitCount = atoi(ptr);

					sprintf(str,"BA E %d %d", Port, WaitCount);
					MemoMain->Lines->Add(AStr + str);
					//Timer1->Enabled = false;
					BaroSendMsg(Port, "\x1B\x1B\x1B");
					WaitCmd(WaitCount);
					//Timer1->Enabled = true;
					break;

				case 'C':
					// BA C cmd, p w  Send cmd to barometer on port p,
					//               wait w seconds. If p=0, send to all.

					ptr = strtok(NULL,",");
					if(NoParam(ptr)) return true; //error
					strcpy(CmdStr, ptr);

					ptr = strtok(NULL," \t");
					if(NoParam(ptr)) return true; //error
					Port = atoi(ptr);

					ptr = strtok(NULL," \t");
					if(NoParam(ptr)) return true; //error
					WaitCount = atoi(ptr);

					sprintf(str,"BA C %s %d %d", CmdStr, Port, WaitCount);
					MemoMain->Lines->Add(AStr + str);
					BaroSendMsg(Port, CmdStr);
					WaitCmd(WaitCount);
					break;

				case 'R':
					// BA R p w  Read barometer on port p, wait w seconds.
					//           If n=0, read all.
					//           If w=0, get reading immediately.

					// GET PORT
					ptr = strtok(NULL," \t");
					if(NoParam(ptr)) return true; //error
					Port = atoi(ptr);

					// GET WAIT COUNT
					ptr = strtok(NULL," \t");
					if(NoParam(ptr)) return true; //error
					WaitCount = atoi(ptr);

					if(EnableSerialCmdOutput->Checked) {
						sprintf(str,"%.1f %.1f", CurrentTemp, CurrentPressure);
						SendSerial(str);
					}

					// READ BARO PORT
					sprintf(str,"BA R %d %d", Port, WaitCount);
					MemoMain->Lines->Add(AStr + str);
					//?Memo2->Update();
					BaroRead(Port);
					if((WaitCount==0) && (Port >0)) {
						while(BaroReadFlag[Port-1]) Application->ProcessMessages();
					}
					else WaitCmd(WaitCount);
					//Timer1->Enabled = true;
					break;

			}
			break;

		case WA_CMD:  // WA w  Wait w seconds

			ptr = strtok(NULL," \t");
			if(NoParam(ptr)) return true; //error
			WaitCount = atoi(ptr);

			sprintf(str,"WA %d", WaitCount);
			MemoMain->Lines->Add(AStr + str);
			WaitCmd(WaitCount);
			break;

		case ST_CMD:  MemoMain->Lines->Add("ST");
			//ProgressBar1->Position = 0;
			MessageBeep(0);
			/*
			if(ReadLogFile) {
				fprintf(ReadLogFile,"0 FINISHED\n");
				ThisTime = Now();
				fprintf(ReadLogFile,"%s\n",ThisTime.c_str());
				ReadLogMonitor->Memo1->Lines->Add(ThisTime);
				fclose(ReadLogFile);
				ReadLogMonitor->Memo1->Lines->Add(ReadLogFileName + " FILE CLOSED.");
			}
			*/
			RunFlag = false;
			return false;
	}

  //while(1) if(ptr != strtok(NULL," \t")) break;
  //while((ptr = strtok(NULL," \t")));

  if(++ScriptIndex >= ScriptCount) RunFlag = false;
  ProgressCount++;
  return false;

}

