    return;
  }

  yMult = (float)Form1->ImageT1->Height/(T[24] - T[0]);

  //sprintf(str,"Mults: %f, %f", xMult, yMult);
  //Form1->MemoMain->Lines->Add(str);

  c->Pen->Color = clSilver;

  for(j=0; j<25; j++) {

