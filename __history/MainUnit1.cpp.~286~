TColor CreateColor(float fVal) {
  // 0.0 to 1.0 == Blue to Green to Red
  float R, G, B;

  fVal *= 2.0;

  if(fVal<0.0 || fVal>2.0) return (TColor) 0;

  if(fVal<=1.0) {
    B = 255.0 * 2.0 * fabs(fVal-1.0);
    G = 255.0 * 2.0 * fVal;
    R = 0.0;
  }
  else {
    B = 0.0;
    G = 255.0 * 2.0 * (2.0 - fVal);
    R = 255.0 * 2.0 * (fVal - 1.0);
    if(R>255.0) R=255.0;
  }
  if(R>255.0) R=255.0;
  if(G>255.0) G=255.0;
  if(B>255.0) B=255.0;
  return (TColor)RGB((BYTE)R,(BYTE)G,(BYTE)B);
}


