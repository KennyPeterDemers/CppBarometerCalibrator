void __fastcall TForm1::Timer1Timer(TObject *Sender)
{
  char str[100];
  int i;
  static int Count = 0;
  TDateTime MyTime;
  double TimerDuration;
  int Days, Hours, Minutes, Seconds;

  // PortMonCount disables the Port Monitor Enable check box
  // after 10 minutes of user inactivity
  if(CheckBoxAutoOff->Checked) {
    if(PortMonCount) --PortMonCount;
    else CheckBoxPortMonEnable->Checked = false;

    //sprintf(str, "%i", PortMonCount);
    //StatusBar1->Panels->Items[1]->Text = str;
  }

	if(ErrFlag) {
		if(EditErrBox->Visible) EditErrBox->Visible = false;
    else EditErrBox->Visible = true;
  }
  else EditErrBox->Visible = false;

	for(i=0; i<DIGI_COMMAND_CHANNELS; i++) ++NoActivityTime[i];

  if(FormTempPressLog->Enabled1->Checked && Count==0) {
		AnsiString ts = Now().FormatString("mm/dd hh:nn:ss");
		sprintf(str, "%s %0.1f C %0.2f hPa", ts.c_str(), CurrentTemp, CurrentPressure);
		FormTempPressLog->MemoTempPressLog->Lines->Add(str);
  }

  ++Count;
  if(Count>=TempPressLogDelay) Count = 0;

  if(TimerFlag) {
    MyTime = Now() -  TimerTime;
    TimerDuration = MyTime;
    Days = (int)TimerDuration;
    TimerDuration -= Days;
    TimerDuration *= 24.0;
    Hours = (int)TimerDuration;
    TimerDuration -= Hours;
    TimerDuration *= 60.0;
    Minutes = (int)TimerDuration;
    TimerDuration -= Minutes;
    TimerDuration *= 60.0;
    Seconds = (int)TimerDuration;

    sprintf(str,"%02dd %02d:%02d:%02d", Days, Hours, Minutes, Seconds);
    LabelTimer->Caption = str;
  }

}
