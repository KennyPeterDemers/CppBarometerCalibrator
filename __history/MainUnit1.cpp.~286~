void __fastcall TForm1::PrintGraph(int PortNum) {

  // All page positions below are in inches

  int x, y, PaperW, PaperH, StringW, LineWidth;
  float xPos, yPos;
  float xMult, yMult, xOffset, yOffset, MinErr, MaxErr, ErrLimit;
  float ySpace;

  int i, j, PressIndex, TempIndex, PressCount, MaxPressCount;
  float  fVal, PressAvg, PressStdev, PressSum,
         LastPress, PressDiff[20][30], PressRef[20], TempRef[30], TempVal[30];

	AnsiString AStr, SerialNumberStr;
  TCanvas *cp;
  char str[300];

  if(ReadBaroIndex == 0) {
    sprintf(str, "No samples for Port %i.", PortNum);
    MemoMain->Lines->Add(str);
		return;
  }

  PressIndex = TempIndex = PressCount = 0;
  MinErr = 9999.9;
  MaxErr = -9999.9;

  MaxPressCount = 0;
  LastPress = 0.0;

  for(i=0; i<ReadBaroIndex; i++) {
    if(ReadBaroArray[i].PortNum == PortNum) {

      fVal = ReadBaroArray[i].RefPressure;
      if(fVal-LastPress > 10.0) {
        LastPress = fVal;
        ++MaxPressCount;
      }
    }
  }

  for(i=0; i<ReadBaroIndex; i++) {
    if(ReadBaroArray[i].PortNum == PortNum) {

      if(CheckBoxOverride->Checked) SerialNumberStr = EditSNOverride->Text;
      else {
				SerialNumberStr = ReadBaroArray[i].SnStr;
        EditSNOverride->Text = SerialNumberStr;
      }

      ++PressCount;

      PressRef[PressIndex] = ReadBaroArray[i].RefPressure;
      TempRef[TempIndex] = ReadBaroArray[i].RefTemp;

      fVal = ReadBaroArray[i].Pressure - ReadBaroArray[i].RefPressure;

      if(CheckBoxOverride->Checked) fVal += StrToFloat(EditOffsetOverride->Text);

      PressDiff[TempIndex][PressIndex] = fVal;
      if(fVal < MinErr) MinErr = fVal;
      if(fVal > MaxErr) MaxErr = fVal;

      if(++PressIndex >= MaxPressCount) {
        TempVal[TempIndex] = ReadBaroArray[i].RefTemp;
        PressIndex = 0;
        ++TempIndex;
        //sprintf(str,"%d %d", i, TempIndex);
        //MemoMain->Lines->Add(str);
        
      }
    }
  }

  if(PressCount == 0) {
    sprintf(str, "No samples for Port %i.", PortNum);
    MemoMain->Lines->Add(str);
    return;
  }

  float  fPressRange, fLowScaleRef, Divisions;
  int XLabelVal;

  switch(RadioGroupGraphSensorType->ItemIndex) {
    //case 0: fPressRange = 700.0;
    //        fLowScaleRef = 400.0;
    //        Divisions = 7.0;
    //        XLabelVal = 400;
    //        break;

    case 0:
    case 1: fPressRange = 600.0;
            fLowScaleRef = 500.0;
            Divisions = 6.0;
            XLabelVal = 500;
            break;

    case 2: fPressRange = 500.0;
            fLowScaleRef = 600.0;
            Divisions = 5.0;
            XLabelVal = 600;
            break;

    case 3: fPressRange = 700.0;
            fLowScaleRef = 400.0;
            Divisions = 7.0;
            XLabelVal = 400;
            break;
  }

  PaperW = Printer()->PageWidth;
  PaperH = Printer()->PageHeight;

  // Convert scale to inches
  // 7.5w x 10h inch surface
  xMult = (float)PaperW/8.0;
  yMult = (float)PaperH/10.5;

  Printer()->Title = "Barometer Graph";
  //Printer()->Title = "Barometer " + EditSerialNum[CSpinEditCalCheckPort->Value - 1]->Text;

  Graphics::TBitmap *LogoImage = new Graphics::TBitmap;
	LogoImage->LoadFromResourceID((int)HInstance, 1000);

  Printer()->BeginDoc();

  cp = Printer()->Canvas;
  cp->Font->Size = 11;
  cp->Font->Color = clBlack;
  cp->Font->Name = "Ariel";

  ySpace = 0.18;
  yPos = 0.75;
  xPos = 0.75;

  x = (int)(xMult * xPos);
  y = (int)(yMult * yPos);
  TRect r = Rect(x, y, x + (int)(0.58 * xMult), y + (int)(0.681 * yMult));
  cp->StretchDraw(r, LogoImage);

  xPos = 1.5;

  cp->TextOut(
    (int)(xPos * xMult),
    (int)(yPos * yMult),
    "R. M. Young Company"
  ); yPos += ySpace;

  cp->TextOut(
    (int)(xPos * xMult),
    (int)(yPos * yMult),
    "Barometric Pressure Sensor Calibration Record"
  ); yPos += ySpace;

  cp->TextOut(
    (int)(xPos * xMult),
    (int)(yPos * yMult),
    "Serial Number: " + SerialNumberStr);

  yPos += ySpace;

  cp->TextOut(
    (int)(xPos * xMult),
    (int)(yPos * yMult),
    "Calibration Date: " + CalTime.FormatString("mmmm dd, yyyy"));

  xPos = 0.75;
  yPos = 1.7;

  MyTextOut(
    cp, //canvas
    (int)(xPos * xMult),
    (int)((yPos + 2.66) * yMult),
    90, // angle
    "Pressure Difference from Reference (hPa)",
    8, //font size
    clBlack);

  xPos = 1.25;

  float GraphW = 5.77;
  float GraphH = 3.33;
  float fXinc = GraphW/Divisions;
  float fYinc = GraphH/10.0;

  float xScale = GraphW/fPressRange;
  float yScale = GraphH/1.0;

  yOffset = GraphH/2.0;

  // --------------------------
  float YLabelVal = 0.5;
  float fX, fY;
  TColor LineColor[30];
  // --------------------------

  cp->Pen->Width = 1;
  cp->Pen->Color = clGray;

  for(fX = 0.0; fX <= (GraphW + 0.01); fX += fXinc) {
    cp->MoveTo((int)((fX + xPos) * xMult), (int)(yPos * yMult));
    cp->LineTo((int)((fX + xPos) * xMult), (int)((yPos + GraphH) * yMult));

    xOffset = -0.11;
    if(XLabelVal < 1000) xOffset = -0.075;

    sprintf(str,"%d", XLabelVal);

    MyTextOut(
      cp, //canvas
      (int)((xPos + fX + xOffset) * xMult),
      (int)((yPos + GraphH + 0.1) * yMult),
      0, // angle
      str,
      7, //font size
      clBlack);

    XLabelVal += 100;
  }

  for(fY = 0.0; fY <= GraphH; fY += fYinc) {
    cp->MoveTo((int)(xPos * xMult)           , (int)((yPos + fY) * yMult));
    cp->LineTo((int)((xPos + GraphW) * xMult), (int)((yPos + fY) * yMult));

    sprintf(str,"%-3.1f  ", YLabelVal);

    MyTextOut(
      cp, //canvas
      (int)((xPos - 0.225) * xMult),
      (int)((yPos + fY - 0.05) * yMult),
      0, // angle
      str,
      7, //font size
      clBlack);

    YLabelVal -= 0.1;
  }

  MyTextOut(
    cp, //canvas
    (int)((xPos + 2.5) * xMult),
    (int)((yPos + 3.6) * yMult),
    0, // angle
    "Pressure (hPa)",
    8, //font size
    clBlack);

  cp->Font->Size = 10;

  cp->TextOut(
    (int)(xPos * xMult),
    (int)((yPos + 4.0) * yMult),
    "LEGEND:");

  BYTE ColorCode;

  for(i=0; i<TempIndex; i++) {
    if(RadioButtonColor->Checked) LineColor[i] = CreateColor((float)i/(float)(TempIndex-1));
    else {
      ColorCode = (i*208)/(TempIndex-1);
      LineColor[i] = (TColor)RGB(ColorCode, ColorCode, ColorCode);
      //sprintf(str,"%d %08X", ColorCode, LineColor[i]);
      //MemoMain->Lines->Add(str);
    }
  }

  LineWidth = (int)(0.04 * xMult);
  // #define PENWIDTH (int)(0.04 * xMult)

  PressSum = 0.0;
  PressCount = 0;

  cp->Pen->Width = LineWidth;

  for(i=0; i<TempIndex; i++) { // Temp

    cp->Pen->Color = LineColor[i];

    sprintf(str,"%.0f°C", TempVal[i]);

    x = (int)(xPos * xMult);
    y = (int)((yPos + 4.0 + (float)(i+1) * ySpace) * yMult);
    cp->TextOut(x, y, str);
    //sprintf(str,"X:%d Y:%d", x,y);
    //MemoMain->Lines->Add(str);

    x = (int)((xPos + 0.5) * xMult);
    y = (int)((yPos + 4.0 + (float)(i+1) * ySpace + ySpace/2.0) * yMult);
    cp->MoveTo(x,y);
    //sprintf(str,"X:%d Y:%d", x,y);
    //MemoMain->Lines->Add(str);

    x = (int)((xPos + 1.0) * xMult);
    y = (int)((yPos + 4.0 + (float)(i+1) * ySpace + ySpace/2.0) * yMult);
    cp->LineTo(x,y);
    //sprintf(str,"X:%d Y:%d", x,y);
    //MemoMain->Lines->Add(str);

    for(j=0; j<MaxPressCount; j++) { // Pressure

      fX = ((PressRef[j] - fLowScaleRef) * xScale + xPos) * xMult;
      fY = (PressDiff[i][j] * -yScale + yOffset + yPos) * yMult;

      PressSum += PressDiff[i][j];
      ++PressCount;

      //sprintf(str,"%03.1f %02.2f", ReadBaroArray[i].RefTemp, PressDiff);
      //MemoMain->Lines->Add(str);

      if(j==0) cp->MoveTo((int)fX, (int)fY);
      else {
        cp->LineTo((int)fX, (int)fY);
      }
    }
  }

  cp->Pen->Color = clWhite;
  cp->Pen->Width = LineWidth;

  cp->MoveTo((int)(xPos * xMult)-LineWidth/2, (int)(yPos * yMult));
  cp->LineTo((int)(xPos * xMult)-LineWidth/2, (int)((yPos + GraphH) * yMult));

  cp->MoveTo((int)((xPos + GraphW) * xMult)+LineWidth/2, (int)(yPos * yMult));
  cp->LineTo((int)((xPos + GraphW) * xMult)+LineWidth/2, (int)((yPos + GraphH) * yMult));

  cp->Pen->Color = clBlack;
  cp->Pen->Width = 10;

  cp->MoveTo((int)(xPos * xMult), (int)(yPos * yMult));
  cp->LineTo((int)(xPos * xMult), (int)((yPos + GraphH) * yMult));
  cp->LineTo((int)((xPos + GraphW) * xMult), (int)((yPos + GraphH) * yMult));
  cp->LineTo((int)((xPos + GraphW) * xMult), (int)(yPos * yMult));
  cp->LineTo((int)(xPos * xMult), (int)(yPos * yMult));

  PressAvg = PressSum/(float)PressCount;
  PressSum = 0.0;


  for(i=0; i<TempIndex; i++) { // Temp
    for(j=0; j<MaxPressCount; j++) { // Pressure
      fVal = PressDiff[i][j] - PressAvg;

      //sprintf(str,"%0.2f", fVal);
      //MemoMain->Lines->Add(str);

      PressSum += (fVal * fVal);
    }
  }

  if(PressCount)
    PressStdev = sqrt(PressSum/(float)PressCount);
  else
    PressStdev = 0.0;

  sprintf(str,"Avg Diff: %0.2f", PressAvg);
  MemoMain->Lines->Add(str);
  sprintf(str,"Std Dev: %0.2f", PressStdev);
  MemoMain->Lines->Add(str);

  //Application->ProcessMessages();

  //xPos = 0.75;
  yPos += 5.5;

  switch(RadioGroupGraphSensorType->ItemIndex) {
    //case 0:   sprintf(str,"Sensor calibration checked from 400 to 1100 hPa in 100 hPa increments at %d temperatures.", TempIndex);
    //          break;

    case 0:
    case 1:   sprintf(str,"Sensor calibration checked from 500 to 1100 hPa in 100 hPa increments at %d temperatures.", TempIndex);
              break;
    case 2:   sprintf(str,"Sensor calibration checked from 600 to 1100 hPa in 100 hPa increments at %d temperatures.", TempIndex);
              break;
              break;
    case 3:   sprintf(str,"Sensor calibration checked from 400 to 1100 hPa in 100 hPa increments at %d temperatures.", TempIndex);
              break;
  }

  // !ATTN! CHANGE TEXT
  cp->TextOut(
    (int)(xPos * xMult),
    (int)(yPos * yMult),
    str);

  yPos += ySpace;

  cp->TextOut(
    (int)(xPos * xMult),
    (int)(yPos * yMult),
    "Pressure reference traceable to NIST.");

  yPos += (2.0 * ySpace);

  sprintf(
    str,
    "Average Difference from Pressure Reference: %0.2f hPa",
    PressAvg);

  cp->TextOut(
    (int)(xPos * xMult),
    (int)(yPos * yMult),
    str);

  yPos += ySpace;

  sprintf(
    str,
    "Standard Deviation: %0.2f hPa",
    PressStdev);

  cp->TextOut(
    (int)(xPos * xMult),
    (int)(yPos * yMult),
    str);

  ErrLimit = EditErrLimit->Text.ToDouble();

  if(MaxErr <= ErrLimit && MinErr >= -ErrLimit)
     MemoMain->Lines->Add("Serial Number " + SerialNumberStr + ": PASS");
  else MemoMain->Lines->Add("Serial Number " + SerialNumberStr + ": FAIL");

  cp->Font->Size = 9;
  cp->Font->Color = clGray;

  yPos = 9.9;

  AStr =  ExtractFileName(CalFileName);
  StringW = cp->TextWidth(AStr);
  x = (PaperW - StringW)/2;
  cp->TextOut(x,(int)(yPos * yMult), AStr);
  yPos += ySpace;

  AStr =  "R. M. Young Company,  2801 Aero Park Drive,  Traverse City, MI 49686 USA";
  StringW = cp->TextWidth(AStr);
  x = (PaperW - StringW)/2;
  cp->TextOut(x,(int)(yPos * yMult), AStr);
  yPos += ySpace;

  AStr =  "CR61200";
  StringW = cp->TextWidth(AStr);
  x = (PaperW - StringW)/2;
  cp->TextOut(x,(int)(yPos * yMult), AStr);

  Printer()->EndDoc();
  delete LogoImage;


}

