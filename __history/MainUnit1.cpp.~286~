TColor __fastcall TForm1::MakeColor(int Temperature) {
  long int R, G, B, RGBVal;
  float NewT;
  char str[100];

  NewT = 55.0 + (float)Temperature;

  if(NewT < 40.0) {
    B = 255L;
    G = (long int)(255.0 * NewT/40.0);
    if(G>255L) G=255L;
    R = 0L;
  }
  else if(NewT >= 80.0) {
    R = 255L;
    G = (long int)(255.0 * (125.0-NewT)/45.0);
    if(G<0L) G=0L;
    B = 0L;
  }
  else {
    G = 255L;
    if(NewT < 60) {
      R = 0L;
      B = (long int)(255.0 * (60.0-NewT)/20.0);
      if(B<0L) B=0L;
    }
    else {
      B = 0L;
      R = (long int)(255.0 * (NewT-60.0)/20.0);
      if(R<0L) R=0L;
    }
  }

  RGBVal = R + 256L * G + 65536L * B + 0x02000000;
  //sprintf(str, "%d %0.0f %08X", Temperature, NewT, RGBVal);
  //MemoMain->Lines->Add(str);

  return (TColor)RGBVal;

}

