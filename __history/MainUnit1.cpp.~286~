// We are not able to turn heater power off via SCPI commands
// Therefore we have to use Ethernet Modbus
// Since SCPI & Ethernet Modbus use different ports we can be connected
// to both byte streams at the same time
// Note: since we are turning off the heater at the end of running a script,
// we have to turn the heater on before we run the next script

void __fastcall TForm1::TemperatureStopModbusTcp()
{
		char str[100];
		const Byte UnitId = 1;
		const int ModbusPort = 502;
		const unsigned short Loop1ControlModeAddr = 2730;
		const unsigned short Loop1ControlActionAddr = 2816;

		std::unique_ptr<TIdTCPClient> client(new TIdTCPClient(nullptr));

		__try {
				if (Active(TcSocket) == false) {
						LogError("ERROR: TemperatureStopModbusTcp(), Temperature Comm Port Closed.");
						return;
				}

				if (Modbus_Connect(client.get(), EditAddrTC->Text, ModbusPort, 2000, 2000) == false) {
						LogError("ERROR: Modbus connect failed.");
						return;
				}
				// Initialize our Modbus transmit ID
				unsigned short txId = 1;

				// Terminate the current profile (don't think it's really needed)
				if (F4T_TerminateProfile(client.get(), txId, UnitId) == false) {
					return;
				}
				// Set Loop1 Control Mode = Off (from auto) allows us to turn heater power off
				if (F4T_SetLoop1ControlModeOff(client.get(), txId, UnitId, Loop1ControlModeAddr) == false) {
					return;
				}
				// Success - but we read the holding reg - just to log the response
				unsigned short valueRead = 0xFFFF;
				TBytes reg;
				if (Modbus_ReadHoldingRegisters(client.get(), txId, UnitId, Loop1ControlModeAddr, 1, reg)) {
						// swap bytes - need at least up through 2 data bytes
						if (reg.Length >= 11) {
								valueRead = (unsigned short)((reg[9] << 8) | reg[10]);
						}
						else {
								SockTracer::Log(TraceKind::Note, "Readback response too short");
						}
						sprintf(str, "Loop1 ControlMode readback= %i", valueRead);
						SockTracer::Log(TraceKind::Note, str);
				}
				// Set Loop1 Control Action = Off (62)
				if (Modbus_WriteSingleRegister(client.get(), txId, UnitId, Loop1ControlActionAddr, HeaterControlActionOff) == false) {
						SockTracer::Log(TraceKind::Note, "Failed to write Loop1 Control Action Off");
						return;
				}
				if (Modbus_ReadHoldingRegisters(client.get(), txId, UnitId, Loop1ControlActionAddr, 1, reg)) {
						// Success - but we read the holding reg - just to log the response
						// swap bytes - need at least up through 2 data bytes
						if (reg.Length >= 11) {
								valueRead = (unsigned short)((reg[9] << 8) | reg[10]);
						}
						else {
								SockTracer::Log(TraceKind::Note, "Readback response too short");
						}
						sprintf(str, "Loop1 ControlAction readback= %i", valueRead);
						SockTracer::Log(TraceKind::Note, str);
				}
		}
		__finally {
        // Don't stay connected
				if (client && client->Connected())
						client->Disconnect();
		}
}

