std::vector<SockTraceEntry> SockTracer::Snapshot()
{
    EnsureInit();
    EnterCriticalSection(&g_cs);
    std::vector<SockTraceEntry> copy = g_entries;
    LeaveCriticalSection(&g_cs);
    return copy;
}

