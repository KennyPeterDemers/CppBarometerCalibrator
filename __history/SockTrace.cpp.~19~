// SockTrace.cpp
#include "SockTrace.h"
#include <windows.h>
#include <stdio.h>

static CRITICAL_SECTION g_cs;
static bool g_inited = false;

static size_t g_maxEntries = 5000;
static size_t g_maxDumpBytes = 256;
static uint64_t g_seq = 0;

static std::vector<SockTraceEntry> g_entries;

void SockTracer::Init(size_t maxEntries, size_t maxBytesToDump)
{
    if (!g_inited)
    {
				InitializeCriticalSection(&g_cs);
        g_inited = true;
    }
    g_maxEntries = maxEntries;
    g_maxDumpBytes = maxBytesToDump;
    g_entries.clear();
    g_entries.reserve(g_maxEntries);
    g_seq = 0;
}

void SockTracer::EnsureInit()
{
    if (!g_inited)
        Init();
}


static std::string ToHex(const uint8_t* p, size_t n)
{
		static const char* k = "0123456789ABCDEF";
		std::string s;
		s.reserve(n * 3);
		for (size_t i = 0; i < n; i++)
		{
				uint8_t b = p[i];
				s.push_back(k[b >> 4]);
				s.push_back(k[b & 0xF]);
				s.push_back(' ');
		}
		return s;
}

static std::string ToAscii(const uint8_t* p, size_t n)
{
		std::string s;
		s.reserve(n);
		for (size_t i = 0; i < n; i++)
		{
				const uint8_t b = p[i];
				s.push_back((b >= 32 && b <= 126) ? (char)b : '.');
		}
		return s;
}

static const char* CtrlName(uint8_t b)
{
    switch (b)
    {
        case 0x1B: return "ESC";
        case 0x0D: return "CR";
        case 0x0A: return "LF";
        case 0x09: return "TAB";
        case 0x20: return "SPACE";
        default:   return nullptr;
    }
}

static std::string ToAsciiNote(const uint8_t* p, size_t n)
{
    std::string s;
    for (size_t i = 0; i < n; i++)
    {
        const char* name = CtrlName(p[i]);
        if (!name) continue;

        // add "i:NAME " tokens
        char buf[32];
        std::snprintf(buf, sizeof(buf), "%u:%s ", (unsigned)i, name);
        s += buf;
    }

    // trim trailing space
    if (!s.empty() && s.back() == ' ') s.pop_back();
    return s;
}

void SockTracer::Log(bool isTx, const char* endpoint, const void* data, int bytes)
{
    EnsureInit();
		if (!endpoint)
		{
			endpoint = "";
		}
		if (!data || bytes <= 0)
		{
			return;
		}
		EnterCriticalSection(&g_cs);

		if (g_entries.size() >= g_maxEntries)
		{
			g_entries.erase(g_entries.begin());
		}
		 SockTraceEntry e;
    e.seq = ++g_seq;
    e.tickMs = GetTickCount();
    e.threadId = GetCurrentThreadId();
    e.endpoint = endpoint;
    e.isTx = isTx;
    e.bytes = bytes;

    size_t n = (size_t)bytes;
		if (n > g_maxDumpBytes)
		{
			n = g_maxDumpBytes;
		}
		e.hex = ToHex((const uint8_t*)data, n);
		e.ascii = ToAscii((const uint8_t*)data, n);
		e.asciiNote = ToAsciiNote((const uint8_t*)data, n);

		if ((size_t)bytes > n)
		{
				e.hex += "...";
				e.ascii += "..."; \
		}
    g_entries.push_back(e);

    LeaveCriticalSection(&g_cs);
}

const std::vector<SockTraceEntry>& SockTracer::Entries()
{
    EnsureInit();
    return g_entries;
}

void SockTracer::DumpToFile(const wchar_t* path)
{
    EnsureInit();
    EnterCriticalSection(&g_cs);

    FILE* f = _wfopen(path, L"wb");
    if (f)
    {
        // header
				fprintf(f, "Seq\tTickMs\t\tThreadId\tEndpoint\t\tDir\tBytes\tHex\tAscii\tAsciiNote\r\n");

        // rows
        for (const auto& e : g_entries)
        {
					fprintf(f, "%llu\t%u\t%u\t%s\t%s\t%04d\t\t%s\t%s\t%s\r\n",
							(unsigned long long)e.seq,
							(unsigned)e.tickMs,
							(unsigned)e.threadId,
							e.endpoint.c_str(),
							e.isTx ? "TX" : "RX",
							e.bytes,
							e.hex.c_str(),
							e.ascii.c_str(),
							e.asciiNote.c_str()
					);
				}

        fclose(f);
    }

    LeaveCriticalSection(&g_cs);
}



