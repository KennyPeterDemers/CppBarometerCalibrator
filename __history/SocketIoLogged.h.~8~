#pragma once
#include <cstring>          // strlen
#include "SockTrace.h"      // SockTracer::Log(...)

// This logs bytes only. It does NOT call SendText.
inline void LogTxText(void* sockTag, const char* text)
{
    if (!sockTag || !text) return;
    const int n = (int)std::strlen(text);
    SockTracer::Log(true, (intptr_t)sockTag, text, n);
}

inline void LogRxText(void* sockTag, const char* text)
{
    if (!sockTag || !text) return;
    const int n = (int)std::strlen(text);
    SockTracer::Log(false, (intptr_t)sockTag, text, n);  // RX log
}

inline void LogTxTextEx(TCustomWinSocket* sock, const char* text)
{
    if (!sock || !text) return;

    // Build "ip:port" endpoint
    AnsiString addr = sock->RemoteAddress;   // UnicodeString -> AnsiString
    int port = sock->RemotePort;

    char ep[128];
    sprintf(ep, "%s:%d", addr.c_str(), port);

    SockTracer::LogEx(true, (intptr_t)sock, ep, text, (int)strlen(text));
}


