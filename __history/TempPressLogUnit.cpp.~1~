void __fastcall TFormTempPressLog::Clear1Click(TObject *Sender)
{
  int mrResult;

  mrResult = Application->MessageBox(
    "All text will be cleared. Are you sure?",
    "Clear Text",
    MB_YESNO);

  if(mrResult == IDYES) {
    MemoTempPressLog->Clear();
  }
}
