#pragma once

#include <cstdio>
#include <cstring>
#include <System.hpp>     // AnsiString
#include "SockTrace.h"

// Build "ip:port" from any socket type that has RemoteAddress / RemotePort
template <typename TSock>
inline void BuildEndpoint(TSock* sock, char* ep, int epSize)
{
    // RemoteAddress is typically UnicodeString; convert to AnsiString
    AnsiString addr = sock->RemoteAddress;
    int port = sock->RemotePort;
    std::snprintf(ep, epSize, "%s:%d", addr.c_str(), port);
}

template <typename TSock>
inline void SendTextLogged(TSock* sock, const char* text)
{
    if (!sock || !text) return;

    char ep[128];
    BuildEndpoint(sock, ep, (int)sizeof(ep));

    SockTracer::Log(true, ep, text, (int)std::strlen(text));
    int bytesSent = sock->SendText(text);
}

template <typename TSock>
inline void LogRxTextLogged(TSock* sock, const char* text)
{
    if (!sock || !text) return;

    char ep[128];
    BuildEndpoint(sock, ep, (int)sizeof(ep));

    SockTracer::Log(false, ep, text, (int)std::strlen(text));
}

